# ===========================================
# FEEDBACK APPLICATION - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill with your actual values
# DO NOT commit the .env file to version control!
# ===========================================
# LOCAL PROFILE
# ===========================================
SPRING_PROFILES_ACTIVE=dev
PORT=8080

# DATABASE CONFIGURATION
# ===========================================
# Local example
DATABASE_URL=jdbc:postgresql://localhost:5432/feedback_dev
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_database_password_here

# Production platforms can keep using a full DATABASE_URL.
# The app also remains compatible with the legacy DEV_DATABASE_URL / DEV_DATABASE_USERNAME / DEV_DATABASE_PASSWORD names.

# JWT CONFIGURATION
# ===========================================
# JWT Secret Key - MUST be at least 32 characters
# Generate a secure key using: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# CORS
# ===========================================
# Comma-separated list
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT Token expiration time in milliseconds
JWT_EXPIRATION=86400000
